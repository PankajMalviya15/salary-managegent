# ──────────────────────────────────────────────
# Backend Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────

# Database connection string.
# For SQLite (development):  sqlite:///./salary_management.db
# For PostgreSQL (production): postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./salary_management.db

# Comma-separated list of allowed CORS origins.
# Use "*" only in development; restrict in production.
CORS_ORIGINS=http://localhost:3000

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
