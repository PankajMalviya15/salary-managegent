# ──────────────────────────────────────────────
# Frontend Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# ──────────────────────────────────────────────

# Base URL of the backend API.
# Uses a relative path so requests go through Next.js rewrites proxy,
# eliminating CORS in both development and production.
NEXT_PUBLIC_API_URL=/api/v1

# Backend server URL (used by next.config.js rewrites).
# Only change this if your backend runs on a different host/port.
BACKEND_URL=http://localhost:8000
